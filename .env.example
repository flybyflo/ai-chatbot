# Generate a random secret: https://generate-secret.vercel.app/32 or `openssl rand -base64 32`
AUTH_SECRET=***

# The following keys below are automatically created and
# added to your environment when you deploy on vercel
# Azure OpenAI Configuration
AZURE_RESOURCE_NAME=***
AZURE_API_KEY=***
AZURE_API_VERSION=2025-01-01-preview

POSTGRES_URL=postgres://postgres:postgres@localhost:5432/ai_chat_app

# Local Redis URL for Docker setup
REDIS_URL=redis://localhost:6379

# Azure Blob Storage Configuration
# Instructions: https://docs.microsoft.com/en-us/azure/storage/blobs/storage-blobs-introduction
AZURE_STORAGE_CONNECTION_STRING=***
AZURE_STORAGE_CONTAINER_NAME=upload

# MCP Server Configuration (optional)
# URL to your MCP server using streamable HTTP transport
MCP_SERVER_URL=http://localhost:8000/mcp
# Optional authentication token for MCP server (Bearer token)
MCP_AUTH_TOKEN=your-auth-token-here
